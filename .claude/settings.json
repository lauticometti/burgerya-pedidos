{
  "permissions": {
    "allow": [
      "Bash(git add *)",
      "Bash(git commit -m ' *)",
      "Bash(git push *)"
    ]
  },
  "hooks": {
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "lsof -i :5173 >/dev/null 2>&1 || npm run dev &",
            "async": true,
            "statusMessage": "Starting dev server..."
          }
        ]
      }
    ]
  }
}
